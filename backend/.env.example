# Environment Variables Configuration
# Copy this file to .env and fill in the values

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/online_bookstore?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# Security Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_min_32_chars
JWT_EXPIRATION_MS=86400000

# Login Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION=15

# Alipay Configuration (沙箱环境)
# 获取方式：https://open.alipay.com -> 开发者中心 -> 沙箱
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_app_private_key
ALIPAY_ALIPAY_PUBLIC_KEY=your_alipay_public_key
