# Environment Variables Configuration
# Copy this file to .env and fill in the values

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/online_bookstore?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# Security Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_min_32_chars
JWT_EXPIRATION_MS=86400000

# Login Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION=15
